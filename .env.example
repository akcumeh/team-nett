# Required: Telegram bot from @BotFather
TG_BOT_TOKEN=
# Secret checked against the x-telegram-bot-api-secret-token header on every webhook update
TG_WEBHOOK_SECRET=

# Required: Supabase project settings
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public HTTPS address of the deployed app, no trailing slash
PUBLIC_BASE_URL=https://your-app.vercel.app
PORT=3000
NODE_ENV=development

# mock = runs the complete demo without touching Monnify
# sandbox = calls https://sandbox.monnify.com
# live = calls https://api.monnify.com
MONNIFY_MODE=mock
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WALLET_ACCOUNT=
MONNIFY_DISBURSEMENTS_ENABLED=false
MONNIFY_MFA_ENABLED=true
# Current docs describe HMAC-SHA512. legacy supports SHA512(secret + rawBody).
MONNIFY_WEBHOOK_SIGNATURE_MODE=auto

# Optional AI invoice/photo extraction. Core commands work without it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional operations settings
ADMIN_TELEGRAM_ID=
DEFAULT_REQUIRED_APPROVALS=2
DAILY_DIGEST_HOUR_UTC=7
BACKGROUND_INTERVAL_MS=60000
SIMULATION_BANNER=true

# Protects api/cron/daily.ts from unauthenticated invocation
CRON_SECRET=
